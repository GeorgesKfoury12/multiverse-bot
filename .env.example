# Copy this file to .env and fill in your bot token from
# https://discord.com/developers/applications -> your app -> Bot -> Token
DISCORD_TOKEN=

# The Discord role that grants Tournament Organizer powers (enable developer
# mode, right-click the role -> Copy Role ID). TO-only commands
# (/tournament create, open/close registration, start) are gated on it.
TO_ROLE_ID=

# Optional: your server's ID. When set, slash commands sync to that guild
# instantly; without it the global sync can take up to an hour to appear.
GUILD_ID=

# Optional: where tournament state lives (SQLite). Defaults to tournaments.db
# in the working directory. Keep this file: it is the full action history
# every restart rebuilds from.
DB_PATH=
